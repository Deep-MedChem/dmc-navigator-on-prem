# Copy to .env (install_navigator.sh does this for you) and edit.
# docker compose reads this file automatically.

# ── Container image ───────────────────────────────────────────────────────────
# Published by Deep-MedChem in AWS ECR. Pull with the credentials we provide
# (`navigator login` uses the AWS CLI for ECR).
DMC_NAV_IMAGE=815935788477.dkr.ecr.us-east-1.amazonaws.com/on-prem/dmc-navigator
DMC_NAV_IMAGE_TAG=latest

# ── Local paths (relative to this repo, or absolute) ──────────────────────────
# Workflow run state (created on demand).
DMC_NAV_RUNS_DIR=./runs
# Your signed license file. `navigator update-license <path>` installs it here.
DMC_NAV_LICENSE_FILE=./license.json
# Optional directory for your own reaction/synthon TSVs and target JSONs.
DMC_NAV_INPUTS_DIR=./inputs

# ── Misc ──────────────────────────────────────────────────────────────────────
# 1 = show Python tracebacks (debugging). Leave empty for clean one-line errors.
DMC_NAV_DEBUG=
