#!/bin/bash
# Sourced by the `navigator` command. Resolves the compose invocation so it
# works from any directory, and makes sure the host mount points exist.
set -euo pipefail

# REPO_FOLDER is exported by ~/.config/dmc-navigator/env.sh (written at install).
if [ -z "${REPO_FOLDER:-}" ] && [ -f "${HOME}/.config/dmc-navigator/env.sh" ]; then
  # shellcheck disable=SC1091
  source "${HOME}/.config/dmc-navigator/env.sh"
fi
: "${REPO_FOLDER:?REPO_FOLDER not set — run install_navigator.sh first}"

COMPOSE_FILE="${REPO_FOLDER}/docker-compose.yml"
[ -f "$COMPOSE_FILE" ] || { echo "compose file not found: $COMPOSE_FILE"; exit 1; }

export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-dmc-navigator}"
# --project-directory makes compose load REPO_FOLDER/.env regardless of cwd.
export COMPOSE_CMD="docker compose -p ${COMPOSE_PROJECT_NAME} --project-directory ${REPO_FOLDER} -f ${COMPOSE_FILE}"

# Ensure the writable mount points exist so `compose run` never fails on a
# missing bind source.
_ensure_dirs() {
  # Pull path values out of .env (fall back to the compose defaults).
  local runs inputs databases key_file
  runs="$(grep -E '^DMC_NAV_RUNS_DIR=' "${REPO_FOLDER}/.env" 2>/dev/null | tail -1 | cut -d= -f2-)"
  inputs="$(grep -E '^DMC_NAV_INPUTS_DIR=' "${REPO_FOLDER}/.env" 2>/dev/null | tail -1 | cut -d= -f2-)"
  databases="$(grep -E '^DMC_NAV_DATABASES_DIR=' "${REPO_FOLDER}/.env" 2>/dev/null | tail -1 | cut -d= -f2-)"
  key_file="$(grep -E '^DMC_NAV_DB_INSTALL_KEY_FILE=' "${REPO_FOLDER}/.env" 2>/dev/null | tail -1 | cut -d= -f2-)"
  runs="${runs:-./runs}"; inputs="${inputs:-./inputs}"; databases="${databases:-./databases}"
  key_file="${key_file:-./db_install.key}"
  case "$runs" in /*) : ;; *) runs="${REPO_FOLDER}/${runs#./}" ;; esac
  case "$inputs" in /*) : ;; *) inputs="${REPO_FOLDER}/${inputs#./}" ;; esac
  case "$databases" in /*) : ;; *) databases="${REPO_FOLDER}/${databases#./}" ;; esac
  case "$key_file" in /*) : ;; *) key_file="${REPO_FOLDER}/${key_file#./}" ;; esac
  mkdir -p "$runs" "$inputs" "$databases"
  # Keep the read-only install-key bind mount valid even before the key arrives.
  [ -e "$key_file" ] || : > "$key_file"
}
_ensure_dirs

# The image reference, for login/pull guidance and the require_image guard.
DMC_NAV_IMAGE="$(grep -E '^DMC_NAV_IMAGE=' "${REPO_FOLDER}/.env" 2>/dev/null | tail -1 | cut -d= -f2-)"
DMC_NAV_IMAGE_TAG="$(grep -E '^DMC_NAV_IMAGE_TAG=' "${REPO_FOLDER}/.env" 2>/dev/null | tail -1 | cut -d= -f2-)"
export DMC_NAV_IMAGE DMC_NAV_IMAGE_TAG
export DMC_NAV_IMAGE_REF="${DMC_NAV_IMAGE:-}:${DMC_NAV_IMAGE_TAG:-stable}"

# A ref is still the unconfigured placeholder if it's empty or starts with
# "replace" (covers both the old REPLACE_ME... and new replace-me... templates).
image_is_placeholder() {
  [ -z "${DMC_NAV_IMAGE:-}" ] && return 0
  case "$DMC_NAV_IMAGE" in
    [Rr][Ee][Pp][Ll][Aa][Cc][Ee]*) return 0 ;;
    *) return 1 ;;
  esac
}

# require_image — commands that run the container call this FIRST so an
# unconfigured/unpulled image yields a clear, actionable message instead of a
# cryptic docker "invalid reference format" / "unable to get image" error.
require_image() {
  if image_is_placeholder; then
    echo "❌ No image configured yet." >&2
    echo "   Set DMC_NAV_IMAGE in ${REPO_FOLDER}/.env to the registry ref from Deep-MedChem," >&2
    echo "   then:  navigator login && navigator pull" >&2
    return 1
  fi
  if ! docker image inspect "$DMC_NAV_IMAGE_REF" >/dev/null 2>&1; then
    echo "❌ Image '${DMC_NAV_IMAGE_REF}' isn't available locally yet." >&2
    echo "   Run:  navigator login && navigator pull" >&2
    return 1
  fi
}
