#!/bin/bash
# Verify the installed license (signature + expiry + this machine's fingerprint).
set -euo pipefail
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "${SELF_DIR}/_compose-env"
require_image || exit 1
exec $COMPOSE_CMD run --rm navigator verify-license
