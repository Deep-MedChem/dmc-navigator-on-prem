#!/bin/bash
# Print this machine's license fingerprint. Send the integer to Deep-MedChem to
# have a license issued.
#
# The fingerprint is derived purely from this host's DMI identity files under
# /sys/devices/virtual/dmi/id — the SAME value the container computes, since a
# container shares the host DMI. So this needs NO image, registry access, or
# license: run it first, before `navigator login`/`pull`.
set -euo pipefail

# Exact port of dmc_license.machine_fingerprint() — MUST stay in sync with it
# (onprem/dmc_license.py in the dmc-navigator-prod repo).
_PY='
import os, hashlib
FIELDS = ["bios_date","uevent","product_name","chassis_vendor","chassis_asset_tag",
"sys_vendor","bios_version","bios_release","product_version","board_vendor",
"chassis_version","product_sku","chassis_type","product_family","bios_vendor",
"board_asset_tag","board_version","modalias","board_name"]
blob = ""
for f in FIELDS:
    p = os.path.join("/sys/devices/virtual/dmi/id", f)
    if os.path.exists(p):
        try:
            blob += open(p).read().strip()
        except OSError:
            continue
print(int(hashlib.md5(blob.encode()).hexdigest(), 16))
'

if command -v python3 >/dev/null 2>&1; then
  exec python3 -c "$_PY"
fi

# Rare fallback: no python3 on the host. Use the image if it's already pulled
# (same code path as verify-license); otherwise ask for python3.
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "${SELF_DIR}/_compose-env"
TAG="$(grep -E '^DMC_NAV_IMAGE_TAG=' "${REPO_FOLDER}/.env" 2>/dev/null | tail -1 | cut -d= -f2-)"
REF="${DMC_NAV_IMAGE:-}:${TAG:-latest}"
if [ -n "${DMC_NAV_IMAGE:-}" ] && docker image inspect "$REF" >/dev/null 2>&1; then
  exec $COMPOSE_CMD run --rm navigator machine-id
fi
echo "python3 is required to compute the machine ID (or pull the image first with 'navigator pull')." >&2
exit 1
